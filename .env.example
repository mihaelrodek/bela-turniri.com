# Copy to `.env` and fill in real values.
# Anything without a default in backend/src/main/resources/application.properties
# MUST be set here, otherwise the Quarkus app will fail to start.

# ── Postgres (used by docker-compose + backend datasource) ─────────────
POSTGRES_DB=bela-turniri.hr
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme

# Optional override — defaults to jdbc:postgresql://localhost:5432/bela-turniri.hr
# POSTGRES_JDBC_URL=jdbc:postgresql://localhost:5432/bela-turniri.hr

# ── MinIO (used by docker-compose + backend StorageService) ────────────
MINIO_ROOT_USER=changeme
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=bela-posters

# Optional overrides — sensible localhost defaults exist in application.properties
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_PUBLIC_BASE_URL=http://localhost:9000
