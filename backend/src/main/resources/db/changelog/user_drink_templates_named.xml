<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
      Named drink templates: a single user can now save multiple cjenik
      templates ("Pivo bar", "Kafić", "Eventi") and pick which one to
      load onto a new tournament. Achieved by adding a template_name
      column to user_drink_templates so rows with the same
      (user_uid, template_name) belong to the same named template.

      Existing rows are migrated under a default name so the user's
      current single template stays accessible after the upgrade.
    -->

    <changeSet id="2026-05-13-user-drink-templates-named" author="mrodek">
        <addColumn tableName="user_drink_templates">
            <column name="template_name" type="varchar(100)"/>
        </addColumn>

        <!-- Backfill old rows into a single, named "Zadani predložak"
             group keyed per user. Done before NOT NULL so no row gets
             rejected by the constraint. -->
        <sql>
            UPDATE user_drink_templates
            SET template_name = 'Zadani predložak'
            WHERE template_name IS NULL;
        </sql>

        <addNotNullConstraint tableName="user_drink_templates" columnName="template_name"/>

        <!-- Drop the old (user_uid, sort_order) index — it's not the
             canonical lookup key anymore. We re-create a wider index. -->
        <dropIndex tableName="user_drink_templates" indexName="idx_udt_user_uid"/>

        <createIndex tableName="user_drink_templates" indexName="idx_udt_user_template">
            <column name="user_uid"/>
            <column name="template_name"/>
            <column name="sort_order"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
