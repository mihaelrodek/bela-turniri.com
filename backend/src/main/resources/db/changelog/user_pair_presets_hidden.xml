<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
      Hidden flag on user pair-name presets. When a user marks one of
      their saved pair names hidden, the public profile view (anyone
      else looking at /profile/{slug}) filters out tournaments where
      this user played as a pair with that name. The owner viewing
      their own profile still sees everything — so hidden is purely
      a "don't display to others" knob, not a delete.
    -->

    <changeSet id="2026-05-13-user-pair-presets-hidden" author="mrodek">
        <addColumn tableName="user_pair_presets">
            <column name="hidden" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
